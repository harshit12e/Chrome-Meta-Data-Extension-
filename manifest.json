{
  "manifest_version": 3,
  "name": "Metadata Watch",
  "description": "Shows what metadata a website can see, requests, stores, and sends while you browse.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Metadata Watch"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "pageProbe.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
